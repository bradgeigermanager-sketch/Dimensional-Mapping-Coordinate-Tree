from .hybridgeometry import hybriddistance, hybrid_angle

def chain_measurements(points):
    """
    Compute pairwise hybrid distances and angles
    for a sequence of points.
    """
    results = []

    for A, B in zip(points, points[1:]):
        results.append({
            "A": A.label,
            "B": B.label,
            "radial_A": abs(A.w),
            "radial_B": abs(B.w),
            "hybriddistance": hybriddistance(A, B),
            "hybridangle": hybridangle(A, B)
        })

    return results
